# Docker Compose interpolation only. Copy to .env locally; never commit the real file.
POSTGRES_DB=mastodon_production
POSTGRES_USER=mastodon
POSTGRES_PASSWORD=CHANGE_ME_GENERATED_BY_SETUP

# Optional until the Cloudflare Tunnel is created.
# The setup/start scripts enable the tunnel profile only when a real token is present.
CLOUDFLARE_TUNNEL_TOKEN=
# Remote CMX two-stage timeline browsing (optional defaults)
CMX_BROWSE_PREVIEW_CHARS=50
CMX_BROWSE_MAX_ITEMS=30
CMX_BROWSE_MAX_OPEN=3
CMX_BROWSE_CHAR_BUDGET=5000
CMX_BROWSE_VISIT_TTL_SECONDS=1800
