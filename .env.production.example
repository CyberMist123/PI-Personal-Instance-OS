# PI OS / Mastodon runtime configuration.
# setup.ps1 copies this file to .env.production and fills the required values.

# Identity — choose once. Changing LOCAL_DOMAIN after real use is unsafe.
LOCAL_DOMAIN=pi.example.com

# Data services
DB_HOST=db
DB_PORT=5432
DB_NAME=mastodon_production
DB_USER=mastodon
DB_PASS=CHANGE_ME_GENERATED_BY_SETUP
REDIS_HOST=redis
REDIS_PORT=6379

# Required secrets — generated by setup.ps1
SECRET_KEY_BASE=
OTP_SECRET=
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=

# Private-instance defaults
LIMITED_FEDERATION_MODE=true
AUTHORIZED_FETCH=true
DISALLOW_UNAUTHENTICATED_API_ACCESS=true
SINGLE_USER_MODE=false

# Interface / deployment
DEFAULT_LOCALE=zh-CN
FORCE_DEFAULT_LOCALE=true
RAILS_SERVE_STATIC_FILES=true
RAILS_LOG_LEVEL=info
LOG_LEVEL=info
ES_ENABLED=false

# Optional SMTP. The owner account is created and confirmed from the CLI,
# so SMTP is not required for the first local beta. Configure it before
# relying on password-reset or invitation emails.
# SMTP_SERVER=smtp.example.com
# SMTP_PORT=587
# SMTP_LOGIN=
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=notifications@pi.example.com
# SMTP_ENABLE_STARTTLS=auto
